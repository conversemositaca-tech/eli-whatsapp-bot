# Puerto del servidor
PORT=3000

# OpenAI
OPENAI_API_KEY=sk-...

# Airtable
AIRTABLE_PAT=pat...
AIRTABLE_BASE_ID=app...

# Evolution API
EVOLUTION_API_URL=https://tu-evolution-api.com
EVOLUTION_API_KEY=tu-api-key
EVOLUTION_INSTANCE=nombre-instancia

# Asistentes por sede (números sin + ni espacios)
ASISTENTE_PIURA=51947709108
ASISTENTE_LIMA=51980453832

# Token para el panel web (/panel y /panel/stickers)
ADMIN_TOKEN=una-clave-secreta

# Traspaso Eli ↔ humano — stickers de control (fileSha256 en base64).
# El operador envía el sticker DENTRO del chat del lead: uno pausa a Eli para
# tomar la conversación, el otro la reactiva. Calibra los hashes enviando cada
# sticker y mirándolos en /panel/stickers?token=... (o en los logs [CTRL]).
# Se admite lista separada por comas.
STICKER_PAUSA_SHA256=
STICKER_REACTIVAR_SHA256=
